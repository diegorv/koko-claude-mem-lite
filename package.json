{
  "name": "memory-lite-plugin",
  "version": "0.1.0",
  "description": "Privacy-first memory plugin for Claude Code",
  "type": "module",
  "scripts": {
    "build": "bun build.ts && vite build",
    "build:worker": "bun build.ts",
    "build:ui": "vite build",
    "dev:ui": "vite",
    "worker:start": "bun plugin/scripts/worker.js",
    "worker:stop": "kill $(cat ~/.memory-lite/worker.pid) 2>/dev/null || true"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.81",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "esbuild": "^0.27.2",
    "svelte": "^5.55.0",
    "typescript": "^5.3.0",
    "vite": "^8.0.2"
  }
}
